Diagnostics:
  Suppress: [pp_expects_filename, unused-includes]
---
If:
  PathMatch: .*\.ino
CompileFlags:
  Add:
    - "-x"
    - "c++"
    - "-include"
    - "Arduino.h"
---
CompileFlags:
  BuiltinHeaders: QueryDriver
Diagnostics:
  Suppress: [pp_expects_filename]
---
# ESP32/Arduino: viele Header sind „Umbrella“-Includes; clangd markiert sie oft fälschlich.
# compile_commands.json: pio run -t compiledb -e esp32-s3-viewe
Diagnostics:
  UnusedIncludes: None
